# =============================================
# CORE -- Required
# =============================================
COMPANY_NAME=Your Company Name
COMPANY_DOMAIN=yourcompany.com
LOGO_FILENAME=company-logo-white.svg

# =============================================
# CMS: WordPress -- Optional
# Enable to push/pull articles, use /library and /wordpress-edit
# =============================================
WORDPRESS_SITE_URL=https://yoursite.com
WORDPRESS_USERNAME=your-username
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
WORDPRESS_DEFAULT_AUTHOR_ID=1
BLOG_PATH=/blog/

# =============================================
# ANALYTICS: Google Analytics 4 -- Optional
# Enable for data-driven content prioritization (/performance-review)
# =============================================
GA4_PROPERTY_ID=your_property_id_here
GA4_CREDENTIALS_PATH=./credentials/ga4-credentials.json

# =============================================
# ANALYTICS: Google Search Console -- Optional
# =============================================
GSC_SITE_URL=https://yoursite.com/
GSC_CREDENTIALS_PATH=./credentials/gsc-credentials.json

# =============================================
# ANALYTICS: DataForSEO -- Optional
# =============================================
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_api_password_here

# =============================================
# VISUAL: Google Gemini -- Optional
# Enable for AI image generation (/generate-images)
# =============================================
GOOGLE_API_KEY=your_gemini_api_key

# =============================================
# DISTRIBUTION: Slack -- Optional
# Enable to send LinkedIn posts to Slack for review
# =============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# =============================================
# PRESENTATIONS: Google Slides -- Optional
# Enable for /slides command
# =============================================
GSLIDES_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
GSLIDES_API_KEY=your-api-key
GSLIDES_TEMPLATE_ID=your-google-slides-template-id

# =============================================
# DOCUMENTS: Google Docs -- Optional
# =============================================
GDOCS_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
GDOCS_API_KEY=your-api-key

# =============================================
# IMAGE HOSTING: HubSpot -- Optional
# Enable for hosting images in Slack/web embeds
# =============================================
HUBSPOT_ACCESS_TOKEN=your-hubspot-access-token

# =============================================
# ASSET BUILDER: PMM Knowledge -- Optional
# Path to a separate repo with personas, messaging, competitive intel
# The /asset command works without this but produces less targeted content
# =============================================
PMM_KNOWLEDGE_PATH=/path/to/your-pmm-repo
